{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api",
        "region": "asia-southeast1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        ".dart_tool"
      ]
    }
  ],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "caretalk-5efcb",
          "appId": "1:808655254753:android:f09b5b07f3cb750f30f3a0",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "caretalk-5efcb",
          "configurations": {
            "android": "1:808655254753:android:f09b5b07f3cb750f30f3a0",
            "web": "1:808655254753:web:0273051b9b46fc0330f3a0"
          }
        }
      }
    }
  }
}
